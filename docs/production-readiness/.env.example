# Production Readiness — 環境変数テンプレート(プレースホルダのみ・設計用)
# 重要: 本ファイルに実際の秘密情報(APIキー/トークン/パスワード)は絶対に記載しない。
# 実値はシークレットマネージャで管理し、ここには参照名/プレースホルダのみを置く。
# すべて example / placeholder であり、CI の秘密情報スキャンでは無視される。

# --- 実行環境(dev | staging | prod) ---
MUSASABI_ENV=dev

# --- 認証・認可(OIDC/OAuth2)。実値はシークレットマネージャ参照 ---
OIDC_ISSUER_URL=<set-in-secret-manager>
OIDC_CLIENT_ID=<set-in-secret-manager>
OIDC_CLIENT_SECRET=<set-in-secret-manager>   # example placeholder only

# --- 本番データベース。接続はシークレット経由 ---
DATABASE_URL=<set-in-secret-manager>          # example placeholder only

# --- ロギング・監視 ---
LOG_LEVEL=info
METRICS_ENDPOINT=<set-in-secret-manager>

# --- シークレットマネージャ(参照名のみ保持) ---
SECRETS_PROVIDER=<vault|kms|example>
SECRETS_PREFIX=musasabi/<env>/

# 実接続・課金・実認証情報は Production Readiness の人間承認後にのみ設定する。
