{
  "name": "@musasabi/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "npm --prefix ../../packages/shared run build && npm --prefix ../../packages/avatar-2d run build && npm --prefix ../../packages/ai-core run build && npm --prefix ../../packages/integrations run build && npm --prefix ../../packages/voice-analysis run build && npm --prefix ../../packages/voice-engine run build && npm --prefix ../sales-workspace run build && tsc -p tsconfig.json",
    "start": "npm run build && electron .",
    "package:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@musasabi/shared": "*",
    "@musasabi/avatar-2d": "*",
    "@musasabi/ai-core": "*",
    "@musasabi/integrations": "*",
    "@musasabi/voice-analysis": "*",
    "@musasabi/voice-engine": "*"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.musasabi.desktop",
    "productName": "Musasabi OS",
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      { "from": "../sales-workspace/dist", "to": "sales-workspace" }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
